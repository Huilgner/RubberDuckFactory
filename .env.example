# =============================================================
# Rubber Duck Factory — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# =============================================================

# --- LLM / AI ---
# OpenRouter (roteador de modelos)  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini (usado pelo orchestrator TypeScript)  https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude (acesso direto à API)  https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# --- MEMÓRIA VETORIAL ---
# Qdrant — URL do servidor (local ou cloud)
QDRANT_URL=http://localhost:6333
# Qdrant — API key (obrigatório apenas em modo cloud)  https://cloud.qdrant.io
QDRANT_API_KEY=

# --- APLICAÇÃO ---
# URL pública onde o serviço está hospedado (para OAuth callbacks, links, etc.)
APP_URL=http://localhost:3000
